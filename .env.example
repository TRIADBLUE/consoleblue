# Required
DATABASE_URL=postgresql://user:password@localhost:5432/consoleblue
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=triadblue
GITHUB_USERNAME=triadblue
CONSOLE_API_KEY=your_secret_api_key_here
SESSION_SECRET=your_session_secret_here

# Optional
CACHE_TTL_DEFAULT=300
SYNC_INTERVAL_MINUTES=30
NODE_ENV=development
PORT=5000

# OGA (Online Global Assets) — public API key for Console.Blue's own favicon/meta
# injection. Generate by creating an ogaSite row for domain "console.blue" via the
# OGA admin UI or the createOgaSite() function, then copy the generated apiKey here.
# Vite substitutes %VITE_OGA_KEY_CONSOLEBLUE% in client/index.html at build time.
VITE_OGA_KEY_CONSOLEBLUE=oga_replace_with_real_key_from_db
